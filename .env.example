SECRET_KEY=your_django_secret_key

DEBUG=True

ALLOWED_HOSTS=127.0.0.1,localhost,host.docker.internal

DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

EMAIL_HOST=your_smtp_server_address
EMAIL_PORT=your_smtp_port_number
EMAIL_USE_TLS=True_or_False
EMAIL_HOST_USER=your_smtp_username_or_email_address
EMAIL_HOST_PASSWORD=your_smtp_password_or_app_specific_password